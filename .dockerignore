# .dockerignore - файлы, которые не копировать в Docker образ

# ============ Система контроля версий ============
.git
.gitignore
.gitattributes

# ============ Конфигурация (КРИТИЧНО - ПАРОЛИ!) ============
.env
.env.local
.env.*.local
.env.production.local

# ============ IDE и редакторы ============
.vscode/
.vscode
.idea/
.idea
*.swp
*.swo
*~
.DS_Store

# ============ Зависимости (пересобираются в Dockerfile) ============
vendor/
node_modules/
# composer.lock  # НУЖЕН для точной установки зависимостей
package-lock.json
yarn.lock

# ============ Логи и временные файлы ============
*.log
logs/
tmp/
temp/
cache/
.cache/

# ============ Документация (не нужна в контейнере) ============
README.md
LICENSE
CHANGELOG.md
docs/

# ============ GitHub/GitLab ============
.github/
.gitlab-ci.yml

# ============ Docker (не копировать сам в себя) ============
Dockerfile
docker-compose*.yml
.dockerignore

# ============ CI/CD ============
.travis.yml
.circleci/
jenkins/

# ============ Тесты (опционально) ============
tests/
phpunit.xml
.phpunit.cache/

# ============ Прочее ============
.editorconfig
.prettierrc
.eslintrc
Makefile
*.bak
*.tmp